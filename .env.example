# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# PostgreSQL connection string (Railway sets this automatically)
# For local dev you can use SQLite (default) or your own Postgres instance
DATABASE_URL=postgresql://user:password@localhost:5432/inv2digikey

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Optional: set this to allow additional user registrations after the first user
# Leave empty to block all new registrations
SETUP_TOKEN=
